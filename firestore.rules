rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - name: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, enum: ['admin', 'user'])
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - description: string (required, size < 200)
    //   - amount: number (required, positive)
    //   - type: string (required, enum: ['income', 'expense'])
    //   - date: string (required)
    //   - category: string (optional, size < 50)
    //   - isBank: bool (optional)
    //   - bankName: string (optional, size < 100)
    //   - userId: string (required, matches auth.token.email)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.uid == "TJb2K6QACOXh3hkhflOhCtmtqEf1" || 
         (request.auth.token.email != null && 
          (request.auth.token.email.lower() == "vitorialuiza418@gmail.com" ||
           request.auth.token.email.lower() == "vitorialuiza418@gmail.com")));
    }

    function isValidTransaction(data) {
      // For super admin, we skip data validation to ensure they can always write
      // For regular users, we validate ownership and data format
      return isSuperAdmin() || (
             (request.auth.token.email != null && data.userId == request.auth.token.email) &&
             data.description is string &&
             data.amount is number &&
             data.type in ['income', 'expense']
      );
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }

    match /transactions/{transactionId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == "TJb2K6QACOXh3hkhflOhCtmtqEf1" || isSuperAdmin());
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.userId == request.auth.token.email);
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isSuperAdmin() || (isAuthenticated() && isValidTransaction(request.resource.data) && resource.data.userId == request.auth.token.email);
      allow delete: if isSuperAdmin() || (isAuthenticated() && resource.data.userId == request.auth.token.email);
    }
  }
}
